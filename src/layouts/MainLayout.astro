---
const { title } = Astro.props;
---
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <title>{title}</title>
    <style is:global>
      body {
        background-color: #0a1a0a;
        color: #d1ffd1;
        font-family: 'Helvetica Neue', Arial, sans-serif;
        margin: 0;
        padding: 2rem;
      }
      nav { margin-bottom: 2rem; border-bottom: 1px solid #2d5a27; padding-bottom: 1rem; }
      a { color: #4ade80; text-decoration: none; margin-right: 1rem; }
    </style>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  </head>
  <body>
    <nav>
      <a href="/">HOME</a>
      <a href="/about">ABOUT</a>
      <a href="/work">WORK</a>
      <a href="/blog">BLOG</a>
      <a href="/news">NEWS</a>
    </nav>
    <main>
      <slot /> 
    </main>
  </body>
</html>